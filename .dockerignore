# Python
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
**/.eggs/
**/build/
**/*.egg

# Virtual environments
**/venv/
**/.venv/
**/env/

# Node
**/node_modules/

# Git
**/.git/
**/.gitignore

# IDE
**/.vscode/
**/.idea/

# OS
**/.DS_Store
**/Thumbs.db

# Secrets — never bake into the image
**/.env

# Build output (rebuilt in Docker)
**/dist/

# Graphify / docs (not needed in container)
**/graphify-out/
**/.gemini/
**/.agents/
